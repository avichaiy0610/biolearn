generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Topic {
  id        String     @id @default(cuid())
  slug      String     @unique
  nameHe    String
  nameEn    String
  descHe    String
  descEn    String
  category  String
  icon      String
  subtopics Subtopic[]
  processes Process[]
}

model Subtopic {
  id                 String  @id @default(cuid())
  topicId            String
  topic              Topic   @relation(fields: [topicId], references: [id])
  slug               String
  nameHe             String
  nameEn             String
  contentHe          String
  contentEn          String
  relatedProcessSlug String? // links to a Process.slug for "view animation" button
  hidden             Boolean       @default(false) // hidden from site but visible in admin
  questions          Question[]
  userProgress       UserProgress[]
  quizResults        QuizResult[]
}

model Process {
  id      String        @id @default(cuid())
  topicId String
  topic   Topic         @relation(fields: [topicId], references: [id])
  slug    String
  nameHe  String
  nameEn  String
  descHe  String
  descEn  String
  steps   ProcessStep[]
}

model ProcessStep {
  id        String  @id @default(cuid())
  processId String
  process   Process @relation(fields: [processId], references: [id])
  order     Int
  titleHe   String
  titleEn   String
  descHe    String
  descEn    String
  svgData   String  // JSON-serialized animation data
}

model UploadedMaterial {
  id          String   @id @default(cuid())
  fileName    String
  topicSlug   String?
  rawText     String
  suggestions String   // JSON: array of suggested subtopics
  approved    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  hashedPassword String
  name           String?
  createdAt      DateTime       @default(now())
  progress       UserProgress[]
  quizResults    QuizResult[]
}

model UserProgress {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subtopicId  String
  subtopic    Subtopic @relation(fields: [subtopicId], references: [id], onDelete: Cascade)
  visited     Boolean  @default(true)
  updatedAt   DateTime @updatedAt

  @@unique([userId, subtopicId])
}

model QuizResult {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subtopicId String
  subtopic   Subtopic @relation(fields: [subtopicId], references: [id], onDelete: Cascade)
  score      Int      // percentage 0-100
  total      Int
  correct    Int
  type       String   @default("official") // "official" | "ai"
  createdAt  DateTime @default(now())
}

model ChatLog {
  id        String   @id @default(cuid())
  topicSlug String?
  topicName String
  question  String
  createdAt DateTime @default(now())
}

model ContentSuggestion {
  id        String   @id @default(cuid())
  topicSlug String?
  topicName String
  nameHe    String
  nameEn    String
  contentHe String
  contentEn String
  slug      String
  reason    String   // Why the AI suggested this
  priority  Int      @default(0) // Higher = more important
  approved  Boolean  @default(false)
  rejected  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Question {
  id           String   @id @default(cuid())
  subtopicId   String
  subtopic     Subtopic @relation(fields: [subtopicId], references: [id])
  type         String   @default("mcq") // "mcq" | "tf" | "open"
  question     String
  options      String?  // JSON: string[] — only for mcq
  answer       String   // correct answer (option text or "true"/"false")
  explanation  String   // why this is the correct answer
  difficulty   String   @default("medium") // "easy" | "medium" | "hard"
  approved     Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model Article {
  id           String   @id @default(cuid())
  pubmedId     String?  @unique // null for uploaded PDFs
  title        String
  authors      String   // JSON: string[]
  journal      String?
  year         Int?
  abstract     String
  abstractHe   String?  // AI-translated Hebrew abstract
  keyFindings  String?  // JSON: string[] of key findings in Hebrew
  topicSlugs   String?  // JSON: string[] of related topic slugs
  subtopicIds  String?  // JSON: string[] of related subtopic IDs
  url          String?  // PubMed / DOI link
  source       String   @default("pubmed") // "pubmed" | "upload"
  hidden       Boolean  @default(true) // requires admin approval before publishing
  createdAt    DateTime @default(now())
}
